# Option A: direct DSN (Cloud SQL Auth Proxy or direct TCP)
DATABASE_URL=postgresql+psycopg2://campconnect_app:CHANGE_ME@127.0.0.1:5432/postgres

# Option B: Google Cloud SQL Python Connector (if set, this mode is used)
CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project:us-central1:your-instance
CLOUD_SQL_DB_USER=campconnect_app
CLOUD_SQL_DB_PASSWORD=CHANGE_ME
CLOUD_SQL_DB_NAME=postgres
CLOUD_SQL_ENABLE_IAM_AUTH=false
CLOUD_SQL_IP_TYPE=PUBLIC

DB_SCHEMA=campConnect
USE_MOCK_DATA=false
API_DEFAULT_PAGE_SIZE=25
API_MAX_PAGE_SIZE=200
MIGRATION_DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@127.0.0.1:5432/postgres
EXPECTED_DB_ROLE=campconnect_app
